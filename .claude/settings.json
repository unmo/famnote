{
  "cleanupPeriodDays": 30,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npx:*)",
      "Bash(cmd /c npm*)",
      "Bash(cmd /c npx*)",
      "Bash(cmd /c git*)",
      "PowerShell(*)",
      "Bash(dir *)",
      "Bash(cmd /c \"npm run build\")",
      "Read(//c/Users/TomokiUmezawa/work/code/skillsync/src/**)",
      "Bash(npm audit *)",
      "Bash(grep -v \"//.*any\")",
      "Write(//c/Users/TomokiUmezawa/work/code/famnote/.claude/loop_state.json)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/secrets/**)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)"
    ],
    "defaultMode": "auto",
    "sandbox": {
      "enabled": true,
      "mode": "strict"
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "count=$(git -C \"$CLAUDE_PROJECT_DIR\" status --short 2>/dev/null | grep -cE '^.M|^ M|^M |^\\?\\?' 2>/dev/null || echo 0); [ \"$count\" -gt 0 ] && printf '{\"systemMessage\": \"\\u26a0\\ufe0f 未コミットの変更が%sファイルあります。/commit スキルを使用してください。\"}' \"$count\" || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "count=$(git -C \"$CLAUDE_PROJECT_DIR\" status --short 2>/dev/null | grep -cE '^.M|^ M|^M |^\\?\\?' 2>/dev/null || echo 0); [ \"$count\" -ge 4 ] && printf '{\"systemMessage\": \"\\u26a0\\ufe0f %sファイルが変更されています。4ファイル以上の大きな変更はagentループ（planner\\u2192designer\\u2192generator\\u2192evaluator）の使用を検討してください。\"}' \"$count\" || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}

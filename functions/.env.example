# Cloud Functions 環境変数（Secret Manager経由でデプロイ環境に設定する）
# ローカル開発時は functions/.env に同内容を記述する（gitignoreに追加済み）

# Stripe秘密鍵（フロントエンドには絶対に公開しない）
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook署名シークレット
STRIPE_WEBHOOK_SECRET=whsec_...

# ¥480パックのStripe Price ID
STRIPE_PRICE_ID=price_...

# フロントエンドのURL（success/cancel URLのベースとして使用）
FRONTEND_URL=http://localhost:5173
